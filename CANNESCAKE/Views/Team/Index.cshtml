@model IEnumerable<CANNESCAKE.Models.TeamMember>

@{
    ViewData["Title"] = "Master Chefs";
}

<!-- Page Header Start -->
<div class="container-fluid bg-dark bg-img p-5 mb-5">
    <div class="row">
        <div class="col-12 text-center">
            <h1 class="display-4 text-uppercase text-white">Usta Aşpazlarımız</h1>
            <a asp-controller="Home" asp-action="Index">Home</a>
            <i class="far fa-square text-primary px-2"></i>
            <a asp-controller="Team" asp-action="Index">Master Chefs</a>
        </div>
    </div>
</div>
<!-- Page Header End -->

<!-- Team Start -->
<div class="container-fluid py-5">
    <div class="container">
        <div class="section-title position-relative text-center mx-auto mb-5 pb-3" style="max-width: 600px;">
            <h2 class="text-primary font-secondary">Komandamız</h2>
            <h1 class="display-4 text-uppercase">Usta Aşpazlarımız</h1>
        </div>
        <div class="row g-5">
            @foreach (var member in Model)
            {
                <div class="col-lg-4 col-md-6">
                    <div class="team-item">
                        <div class="position-relative overflow-hidden">
                            @if (!string.IsNullOrEmpty(member.ImageUrl))
                            {
                                <img class="img-fluid w-100" src="@member.ImageUrl" alt="@member.FullName">
                            }
                            else
                            {
                                <img class="img-fluid w-100" src="~/assets/img/team-1.jpg" alt="@member.FullName">
                            }
                            <div class="team-overlay w-100 h-100 position-absolute top-50 start-50 translate-middle d-flex align-items-center justify-content-center">
                                <div class="d-flex align-items-center justify-content-start">
                                    @if (!string.IsNullOrEmpty(member.TwitterUrl))
                                    {
                                        <a class="btn btn-lg btn-primary btn-lg-square border-inner rounded-0 mx-1" href="@member.TwitterUrl"><i class="fab fa-twitter fw-normal"></i></a>
                                    }
                                    @if (!string.IsNullOrEmpty(member.FacebookUrl))
                                    {
                                        <a class="btn btn-lg btn-primary btn-lg-square border-inner rounded-0 mx-1" href="@member.FacebookUrl"><i class="fab fa-facebook-f fw-normal"></i></a>
                                    }
                                    @if (!string.IsNullOrEmpty(member.InstagramUrl))
                                    {
                                        <a class="btn btn-lg btn-primary btn-lg-square border-inner rounded-0 mx-1" href="@member.InstagramUrl"><i class="fab fa-instagram fw-normal"></i></a>
                                    }
                                </div>
                            </div>
                        </div>
                        <div class="bg-dark border-inner text-center p-4">
                            <h4 class="text-uppercase text-primary">@member.FullName</h4>
                            <p class="text-white m-0">@member.Position</p>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>
<!-- Team End -->

<!-- About Team Section -->
<div class="container-fluid py-5">
    <div class="container">
        <div class="section-title position-relative text-center mx-auto mb-5 pb-3" style="max-width: 600px;">
            <h2 class="text-primary font-secondary">Biz kimik?</h2>
            <h1 class="display-4 text-uppercase">Peşəkar Komandamız</h1>
        </div>
        <div class="row gx-5">
            <div class="col-lg-5 mb-5 mb-lg-0" style="min-height: 400px;">
                <div class="position-relative h-100">
                    <img class="position-absolute w-100 h-100" src="~/assets/img/about.jpg" style="object-fit: cover;" alt="Komandamız">
                </div>
            </div>
            <div class="col-lg-6 pb-5">
                <h4 class="mb-4">Hər bir tortumuzun arxasında peşəkar və həvəsli bir komanda dayanır</h4>
                <p class="mb-5">Cannes Cake komandası illərdir tort sənəti sahəsində çalışan peşəkarlardan ibarətdir. Hər bir üzvümüz öz sahəsində mütəxəssisdir və müştərilərimizin xüsusi anlarını daha da xüsusi etmək üçün bütün bacarığını ortaya qoyur. Biz yalnız tort hazırlamırıq — xatirələr yaradırıq.</p>
                <div class="row g-5">
                    <div class="col-sm-6">
                        <div class="d-flex align-items-center justify-content-center bg-primary border-inner mb-4" style="width: 90px; height: 90px;">
                            <i class="fa fa-certificate fa-2x text-white"></i>
                        </div>
                        <h4 class="text-uppercase">Sertifikatlı</h4>
                        <p class="mb-0">Bütün aşpazlarımız beynəlxalq sertifikatlara malikdir və daim peşəkar inkişaf kurslarına qatılır.</p>
                    </div>
                    <div class="col-sm-6">
                        <div class="d-flex align-items-center justify-content-center bg-primary border-inner mb-4" style="width: 90px; height: 90px;">
                            <i class="fa fa-users fa-2x text-white"></i>
                        </div>
                        <h4 class="text-uppercase">Komanda Ruhu</h4>
                        <p class="mb-0">Hər bir sifariş komanda işi ilə hazırlanır. Dizayndan dadmağa qədər hər detal nəzarət altındadır.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
