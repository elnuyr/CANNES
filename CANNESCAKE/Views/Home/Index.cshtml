@{
    ViewData["Title"] = "Ana Səhifə";
}

<!-- Hero Start -->
<div class="container-fluid bg-primary py-5 mb-5 hero-header">
    <div class="container py-5">
        <div class="row justify-content-start">
            <div class="col-lg-8 text-center text-lg-start">
                <h1 class="font-secondary text-primary mb-4">Super Dadlı</h1>
                <h1 class="display-1 text-uppercase text-white mb-4">Cannes Cake</h1>
                <h1 class="text-uppercase text-white">Ən Yaxşı Tortlar</h1>
                <div class="d-flex align-items-center justify-content-center justify-content-lg-start pt-5">
                    <a asp-controller="Menu" asp-action="Index" class="btn btn-primary border-inner py-3 px-5 me-5">Menyu</a>
                    <button type="button" class="btn-play" data-bs-toggle="modal"
                            data-src="https://www.youtube.com/embed/-Nckfxm_RU0" data-bs-target="#videoModal">
                        <span></span>
                    </button>
                    <h5 class="font-weight-normal text-white m-0 ms-4 d-none d-sm-block">Video İzlə</h5>
                </div>
            </div>
        </div>  
    </div>
</div>
<!-- Hero End -->

<!-- Video Modal Start -->
<div class="modal fade" id="videoModal" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content rounded-0">
            <div class="modal-header">
                <h5 class="modal-title" id="exampleModalLabel">Video</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Bağla"></button>
            </div>
            <div class="modal-body">
                <!-- 16:9 aspect ratio -->
                <div class="ratio ratio-16x9">
                    <iframe class="embed-responsive-item" src="" id="video" allowfullscreen allowscriptaccess="always"
                            allow="autoplay"></iframe>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- Video Modal End -->

<!-- About Start -->
<div class="container-fluid pt-5">
    <div class="container">
        <div class="section-title position-relative text-center mx-auto mb-5 pb-3" style="max-width: 600px;">
            <h2 class="text-primary font-secondary">Haqqımızda</h2>
            <h1 class="display-4 text-uppercase">Cannes Cake-ə Xoş Gəldiniz</h1>
        </div>
        <div class="row gx-5">
            <div class="col-lg-5 mb-5 mb-lg-0" style="min-height: 400px;">
                <div class="position-relative h-100">
                    <img class="position-absolute w-100 h-100" src="~/assets/img/about.jpg" style="object-fit: cover;" alt="Haqqımızda">
                </div>
            </div>
            <div class="col-lg-6 pb-5">
                <h4 class="mb-4">Biz hər bir tortu sevgi və ustalıqla hazırlayırıq. Keyfiyyətli təbii inqrediyentlər istifadə edirik</h4>
                <p class="mb-5">Cannes Cake olaraq, müştərilərimizə ən yüksək keyfiyyətli tortlar təqdim etməyi hədəfləyirik. Hər bir tortumuz təzə və təbii inqrediyentlərlə hazırlanır. Ad günü, toy, nişan və xüsusi münasibətlər üçün xüsusi tortlar sifariş edə bilərsiniz.</p>
                <div class="row g-5">
                    <div class="col-sm-6">
                        <div class="d-flex align-items-center justify-content-center bg-primary border-inner mb-4" style="width: 90px; height: 90px;">
                            <i class="fa fa-heartbeat fa-2x text-white"></i>
                        </div>
                        <h4 class="text-uppercase">100% Təbii</h4>
                        <p class="mb-0">Bütün tortlarımız təbii inqrediyentlərdən hazırlanır. Heç bir süni qatqı istifadə etmirik.</p>
                    </div>
                    <div class="col-sm-6">
                        <div class="d-flex align-items-center justify-content-center bg-primary border-inner mb-4" style="width: 90px; height: 90px;">
                            <i class="fa fa-award fa-2x text-white"></i>
                        </div>
                        <h4 class="text-uppercase">Mükafatlı</h4>
                        <p class="mb-0">Peşəkar komandamız tərəfindən hazırlanan tortlarımız müxtəlif mükafatlara layiq görülmüşdür.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- About End -->

<!-- Facts Start -->
<div class="container-fluid bg-img py-5 mb-5">
    <div class="container py-5">
        <div class="row gx-5 gy-4">
            <div class="col-lg-3 col-md-6">
                <div class="d-flex">
                    <div class="bg-primary border-inner d-flex align-items-center justify-content-center mb-3" style="width: 60px; height: 60px;">
                        <i class="fa fa-star text-white"></i>
                    </div>
                    <div class="ps-4">
                        <h6 class="text-primary text-uppercase">Təcrübə (il)</h6>
                        <h1 class="display-5 text-white mb-0" data-toggle="counter-up">10</h1>
                    </div>
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <div class="d-flex">
                    <div class="bg-primary border-inner d-flex align-items-center justify-content-center mb-3" style="width: 60px; height: 60px;">
                        <i class="fa fa-users text-white"></i>
                    </div>
                    <div class="ps-4">
                        <h6 class="text-primary text-uppercase">Usta Aşpazlar</h6>
                        <h1 class="display-5 text-white mb-0" data-toggle="counter-up">15</h1>
                    </div>
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <div class="d-flex">
                    <div class="bg-primary border-inner d-flex align-items-center justify-content-center mb-3" style="width: 60px; height: 60px;">
                        <i class="fa fa-check text-white"></i>
                    </div>
                    <div class="ps-4">
                        <h6 class="text-primary text-uppercase">Tamamlanmış Sifarişlər</h6>
                        <h1 class="display-5 text-white mb-0" data-toggle="counter-up">5000</h1>
                    </div>
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <div class="d-flex">
                    <div class="bg-primary border-inner d-flex align-items-center justify-content-center mb-3" style="width: 60px; height: 60px;">
                        <i class="fa fa-mug-hot text-white"></i>
                    </div>
                    <div class="ps-4">
                        <h6 class="text-primary text-uppercase">Xoşbəxt Müştərilər</h6>
                        <h1 class="display-5 text-white mb-0" data-toggle="counter-up">4997</h1>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- Facts End -->

<!-- Products Start -->
<div class="container-fluid about py-5">
    <div class="container">
        <div class="section-title position-relative text-center mx-auto mb-5 pb-3" style="max-width: 600px;">
            <h2 class="text-primary font-secondary">Menyu & Qiymətlər</h2>
            <h1 class="display-4 text-uppercase">Tortlarımızı Kəşf Edin</h1>
        </div>
        <div class="tab-class text-center">
            <ul class="nav nav-pills d-inline-flex justify-content-center bg-dark text-uppercase border-inner p-4 mb-5">
                @{ var catIndex = 0; }
                @foreach (var category in (IEnumerable<CANNESCAKE.Models.Category>)ViewBag.Categories)
                {
                    <li class="nav-item">
                        <a class="nav-link text-white @(catIndex == 0 ? "active" : "")" data-bs-toggle="pill" href="#tab-@category.Id">@category.Name</a>
                    </li>
                    catIndex++;
                }
            </ul>
            <div class="tab-content">
                @{ catIndex = 0; }
                @foreach (var category in (IEnumerable<CANNESCAKE.Models.Category>)ViewBag.Categories)
                {
                    <div id="tab-@category.Id" class="tab-pane fade show p-0 @(catIndex == 0 ? "active" : "")">
                        <div class="row g-3">
                            @foreach (var cake in category.Cakes)
                            {
                                <div class="col-lg-6">
                                    <div class="d-flex h-100">
                                        <div class="flex-shrink-0">
                                            @if (!string.IsNullOrEmpty(cake.ImageUrl))
                                            {
                                                <img class="img-fluid" src="@cake.ImageUrl" alt="@cake.Name" style="width: 150px; height: 85px; object-fit: cover;">
                                            }
                                            else
                                            {
                                                <img class="img-fluid" src="~/assets/img/cake-1.jpg" alt="@cake.Name" style="width: 150px; height: 85px; object-fit: cover;">
                                            }
                                            <h4 class="bg-dark text-primary p-2 m-0">₼@cake.Price.ToString("F2")</h4>
                                        </div>
                                        <div class="d-flex flex-column justify-content-center text-start bg-secondary border-inner px-4 w-100">
                                            <h5 class="text-uppercase">@cake.Name</h5>
                                            <span>@cake.Description</span>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                    catIndex++;
                }
            </div>
        </div>
    </div>
</div>
<!-- Products End -->

<!-- Service Start -->
<div class="container-fluid service position-relative px-5 mt-5" style="margin-bottom: 135px;">
    <div class="container">
        <div class="row g-5">
            <div class="col-lg-4 col-md-6">
                <div class="bg-primary border-inner text-center text-white p-5">
                    <h4 class="text-uppercase mb-3">Ad Günü Tortları</h4>
                    <p>Uşaqlar və böyüklər üçün xüsusi dizaynlı ad günü tortları hazırlayırıq. İstənilən mövzu və ölçüdə.</p>
                    <a class="text-uppercase text-dark" asp-controller="Menu" asp-action="Index">Ətraflı <i class="bi bi-arrow-right"></i></a>
                </div>
            </div>
            <div class="col-lg-4 col-md-6">
                <div class="bg-primary border-inner text-center text-white p-5">
                    <h4 class="text-uppercase mb-3">Toy Tortları</h4>
                    <p>Ən xüsusi gününüz üçün möhtəşəm çox mərtəbəli toy tortları. Hər detal sizin zövqünüzə uyğun.</p>
                    <a class="text-uppercase text-dark" asp-controller="Menu" asp-action="Index">Ətraflı <i class="bi bi-arrow-right"></i></a>
                </div>
            </div>
            <div class="col-lg-4 col-md-6">
                <div class="bg-primary border-inner text-center text-white p-5">
                    <h4 class="text-uppercase mb-3">Xüsusi Dizayn</h4>
                    <p>Təxəyyülünüzü reallığa çeviririk. Foto tort, 3D tort, fondant tort — istədiyiniz hər şeyi hazırlaya bilərik.</p>
                    <a class="text-uppercase text-dark" asp-controller="Menu" asp-action="Index">Ətraflı <i class="bi bi-arrow-right"></i></a>
                </div>
            </div>
            <div class="col-lg-12 col-md-6 text-center">
                <h1 class="text-uppercase text-light mb-4">Bu Yay 30% Endirim!</h1>
                <a asp-controller="Contact" asp-action="Index" class="btn btn-primary border-inner py-3 px-5">İndi Sifariş Et</a>
            </div>
        </div>
    </div>
</div>
<!-- Service End -->

<!-- Team Start -->
<div class="container-fluid py-5">
    <div class="container">
        <div class="section-title position-relative text-center mx-auto mb-5 pb-3" style="max-width: 600px;">
            <h2 class="text-primary font-secondary">Komandamız</h2>
            <h1 class="display-4 text-uppercase">Usta Aşpazlarımız</h1>
        </div>
        <div class="row g-5">
            @foreach (var member in (IEnumerable<CANNESCAKE.Models.TeamMember>)ViewBag.TeamMembers)
            {
                <div class="col-lg-4 col-md-6">
                    <div class="team-item">
                        <div class="position-relative overflow-hidden">
                            @if (!string.IsNullOrEmpty(member.ImageUrl))
                            {
                                <img class="img-fluid w-100" src="@member.ImageUrl" alt="@member.FullName">
                            }
                            else
                            {
                                <img class="img-fluid w-100" src="~/assets/img/team-1.jpg" alt="@member.FullName">
                            }
                            <div class="team-overlay w-100 h-100 position-absolute top-50 start-50 translate-middle d-flex align-items-center justify-content-center">
                                <div class="d-flex align-items-center justify-content-start">
                                    @if (!string.IsNullOrEmpty(member.TwitterUrl))
                                    {
                                        <a class="btn btn-lg btn-primary btn-lg-square border-inner rounded-0 mx-1" href="@member.TwitterUrl"><i class="fab fa-twitter fw-normal"></i></a>
                                    }
                                    @if (!string.IsNullOrEmpty(member.FacebookUrl))
                                    {
                                        <a class="btn btn-lg btn-primary btn-lg-square border-inner rounded-0 mx-1" href="@member.FacebookUrl"><i class="fab fa-facebook-f fw-normal"></i></a>
                                    }
                                    @if (!string.IsNullOrEmpty(member.InstagramUrl))
                                    {
                                        <a class="btn btn-lg btn-primary btn-lg-square border-inner rounded-0 mx-1" href="@member.InstagramUrl"><i class="fab fa-instagram fw-normal"></i></a>
                                    }
                                </div>
                            </div>
                        </div>
                        <div class="bg-dark border-inner text-center p-4">
                            <h4 class="text-uppercase text-primary">@member.FullName</h4>
                            <p class="text-white m-0">@member.Position</p>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>
<!-- Team End -->

<!-- Offer Start -->
<div class="container-fluid bg-offer my-5 py-5">
    <div class="container py-5">
        <div class="row gx-5 justify-content-center">
            <div class="col-lg-7 text-center">
                <div class="section-title position-relative text-center mx-auto mb-4 pb-3" style="max-width: 600px;">
                    <h2 class="text-primary font-secondary">Xüsusi Kombo Paket</h2>
                    <h1 class="display-4 text-uppercase text-white">Super Dadlı Tortlar</h1>
                </div>
                <p class="text-white mb-4">Xüsusi münasibətlər üçün kombo paketlərimizdən yararlanın. Ad günü, nişan və ya toy üçün tort + cupcake + macarons dəsti sifariş edin və 20% endirim qazanın!</p>
                <a asp-controller="Contact" asp-action="Index" class="btn btn-primary border-inner py-3 px-5 me-3">Sifariş Et</a>
                <a asp-controller="About" asp-action="Index" class="btn btn-dark border-inner py-3 px-5">Ətraflı</a>
            </div>
        </div>
    </div>
</div>
<!-- Offer End -->

<!-- Testimonial Start -->
<div class="container-fluid py-5">
    <div class="container">
        <div class="section-title position-relative text-center mx-auto mb-5 pb-3" style="max-width: 600px;">
            <h2 class="text-primary font-secondary">Müştəri Rəyləri</h2>
            <h1 class="display-4 text-uppercase">Müştərilərimiz Nə Deyir?</h1>
        </div>
        <div class="owl-carousel testimonial-carousel">
            @foreach (var item in (IEnumerable<CANNESCAKE.Models.Testimonial>)ViewBag.Testimonials)
            {
                <div class="testimonial-item bg-dark text-white border-inner p-4">
                    <div class="d-flex align-items-center mb-3">
                        @if (!string.IsNullOrEmpty(item.ImageUrl))
                        {
                            <img class="img-fluid flex-shrink-0" src="@item.ImageUrl" style="width: 60px; height: 60px; border-radius: 50%; object-fit: cover;" alt="@item.ClientName">
                        }
                        else
                        {
                            <img class="img-fluid flex-shrink-0" src="~/assets/img/testimonial-1.jpg" style="width: 60px; height: 60px;" alt="@item.ClientName">
                        }
                        <div class="ps-3">
                            <h4 class="text-primary text-uppercase mb-1">@item.ClientName</h4>
                            <span>@item.Profession</span>
                        </div>
                    </div>
                    <p class="mb-0">@item.Comment</p>
                </div>
            }
        </div>
    </div>
</div>
<!-- Testimonial End -->
