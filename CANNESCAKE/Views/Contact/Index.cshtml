@model CANNESCAKE.Models.ContactMessage

@{
    ViewData["Title"] = "Contact Us";
}

<!-- Page Header Start -->
<div class="container-fluid bg-dark bg-img p-5 mb-5">
    <div class="row">
        <div class="col-12 text-center">
            <h1 class="display-4 text-uppercase text-white">Əlaqə</h1>
            <a asp-controller="Home" asp-action="Index">Home</a>
            <i class="far fa-square text-primary px-2"></i>
            <a asp-controller="Contact" asp-action="Index">Contact</a>
        </div>
    </div>
</div>
<!-- Page Header End -->

<!-- Contact Start -->
<div class="container-fluid py-5">
    <div class="container">
        <div class="section-title position-relative text-center mx-auto mb-5 pb-3" style="max-width: 600px;">
            <h2 class="text-primary font-secondary">Əlaqə</h2>
            <h1 class="display-4 text-uppercase">Bizimlə Əlaqə Saxlayın</h1>
        </div>
        <div class="row gx-5 mb-5">
            <div class="col-md-4">
                <div class="bg-primary border-inner text-center text-white p-5 h-100">
                    <div class="d-flex align-items-center justify-content-center mx-auto mb-3" style="width: 90px; height: 90px;">
                        <i class="fa fa-map-marker-alt fa-3x text-dark"></i>
                    </div>
                    <h4 class="text-uppercase mb-3">Ünvanımız</h4>
                    <p class="mb-0">Bakı şəhəri, Nəsimi rayonu, Nizami küçəsi 50</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="bg-primary border-inner text-center text-white p-5 h-100">
                    <div class="d-flex align-items-center justify-content-center mx-auto mb-3" style="width: 90px; height: 90px;">
                        <i class="fa fa-phone-alt fa-3x text-dark"></i>
                    </div>
                    <h4 class="text-uppercase mb-3">Telefon</h4>
                    <p class="mb-0">+994 50 123 45 67</p>
                    <p class="mb-0">+994 12 345 67 89</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="bg-primary border-inner text-center text-white p-5 h-100">
                    <div class="d-flex align-items-center justify-content-center mx-auto mb-3" style="width: 90px; height: 90px;">
                        <i class="fa fa-envelope fa-3x text-dark"></i>
                    </div>
                    <h4 class="text-uppercase mb-3">E-poçt</h4>
                    <p class="mb-0">info@cannescake.az</p>
                    <p class="mb-0">order@cannescake.az</p>
                </div>
            </div>
        </div>
        <div class="row gx-5">
            <div class="col-lg-6 mb-5 mb-lg-0">
                <div class="bg-secondary border-inner p-5">
                    <h4 class="text-uppercase mb-4">Bizə Mesaj Göndərin</h4>
                    @if (TempData["Success"] != null)
                    {
                        <div class="alert alert-success">@TempData["Success"]</div>
                    }
                    <form asp-action="Index" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <div class="form-floating">
                                    <input asp-for="Name" class="form-control border-0" placeholder="Adınız">
                                    <label asp-for="Name">Adınız</label>
                                    <span asp-validation-for="Name" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-floating">
                                    <input asp-for="Email" class="form-control border-0" placeholder="E-poçt">
                                    <label asp-for="Email">E-poçt</label>
                                    <span asp-validation-for="Email" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-12">
                                <div class="form-floating">
                                    <input asp-for="Subject" class="form-control border-0" placeholder="Mövzu">
                                    <label asp-for="Subject">Mövzu</label>
                                </div>
                            </div>
                            <div class="col-12">
                                <div class="form-floating">
                                    <textarea asp-for="Message" class="form-control border-0" placeholder="Mesajınız" style="height: 200px"></textarea>
                                    <label asp-for="Message">Mesajınız</label>
                                    <span asp-validation-for="Message" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-12">
                                <button class="btn btn-primary border-inner w-100 py-3" type="submit">Göndər</button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="position-relative h-100" style="min-height: 400px;">
                    <iframe class="position-absolute w-100 h-100" style="border: 0;"
                            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3039.4298367080955!2d49.8520!3d40.4093!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zNDDCsDI0JzMzLjUiTiA0OcKwNTEnMDcuMiJF!5e0!3m2!1saz!2saz!4v1234567890"
                            allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade">
                    </iframe>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- Contact End -->

<!-- Working Hours Start -->
<div class="container-fluid bg-img py-5 my-5">
    <div class="container py-5">
        <div class="section-title position-relative text-center mx-auto mb-5 pb-3" style="max-width: 600px;">
            <h2 class="text-primary font-secondary">İş Saatlarımız</h2>
            <h1 class="display-4 text-uppercase text-white">Nə vaxt açığıq?</h1>
        </div>
        <div class="row gx-5 justify-content-center">
            <div class="col-lg-6">
                <div class="bg-dark border-inner text-center text-white p-5">
                    <div class="d-flex justify-content-between border-bottom border-secondary pb-3 mb-3">
                        <span>Bazar ertəsi - Cümə</span>
                        <span class="text-primary">09:00 - 21:00</span>
                    </div>
                    <div class="d-flex justify-content-between border-bottom border-secondary pb-3 mb-3">
                        <span>Şənbə</span>
                        <span class="text-primary">10:00 - 22:00</span>
                    </div>
                    <div class="d-flex justify-content-between">
                        <span>Bazar</span>
                        <span class="text-primary">10:00 - 20:00</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- Working Hours End -->
