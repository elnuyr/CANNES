@{
    ViewData["Title"] = "Our Services";
}

<!-- Page Header Start -->
<div class="container-fluid bg-dark bg-img p-5 mb-5">
    <div class="row">
        <div class="col-12 text-center">
            <h1 class="display-4 text-uppercase text-white">Xidmətlərimiz</h1>
            <a asp-controller="Home" asp-action="Index">Home</a>
            <i class="far fa-square text-primary px-2"></i>
            <a asp-controller="Service" asp-action="Index">Service</a>
        </div>
    </div>
</div>
<!-- Page Header End -->

<!-- Service Start -->
<div class="container-fluid service position-relative px-5 mt-5" style="margin-bottom: 135px;">
    <div class="container">
        <div class="section-title position-relative text-center mx-auto mb-5 pb-3" style="max-width: 600px;">
            <h2 class="text-primary font-secondary">Xidmətlərimiz</h2>
            <h1 class="display-4 text-uppercase">Nə Təklif Edirik?</h1>
        </div>
        <div class="row g-5">
            <div class="col-lg-4 col-md-6">
                <div class="bg-primary border-inner text-center text-white p-5">
                    <div class="d-flex align-items-center justify-content-center mx-auto mb-3" style="width: 90px; height: 90px;">
                        <i class="fa fa-birthday-cake fa-3x text-dark"></i>
                    </div>
                    <h4 class="text-uppercase mb-3">Ad Günü Tortları</h4>
                    <p>Uşaqlar və böyüklər üçün xüsusi dizaynlı ad günü tortları hazırlayırıq. İstənilən mövzu və ölçüdə sifarişlər qəbul edirik.</p>
                    <a class="text-uppercase text-dark" asp-controller="Menu" asp-action="Index">Ətraflı <i class="bi bi-arrow-right"></i></a>
                </div>
            </div>
            <div class="col-lg-4 col-md-6">
                <div class="bg-primary border-inner text-center text-white p-5">
                    <div class="d-flex align-items-center justify-content-center mx-auto mb-3" style="width: 90px; height: 90px;">
                        <i class="fa fa-heart fa-3x text-dark"></i>
                    </div>
                    <h4 class="text-uppercase mb-3">Toy Tortları</h4>
                    <p>Ən xüsusi gününüz üçün möhtəşəm çox mərtəbəli toy tortları. Hər bir detal sizin zövqünüzə uyğun hazırlanır.</p>
                    <a class="text-uppercase text-dark" asp-controller="Menu" asp-action="Index">Ətraflı <i class="bi bi-arrow-right"></i></a>
                </div>
            </div>
            <div class="col-lg-4 col-md-6">
                <div class="bg-primary border-inner text-center text-white p-5">
                    <div class="d-flex align-items-center justify-content-center mx-auto mb-3" style="width: 90px; height: 90px;">
                        <i class="fa fa-palette fa-3x text-dark"></i>
                    </div>
                    <h4 class="text-uppercase mb-3">Xüsusi Dizayn</h4>
                    <p>Təxəyyülünüzü reallığa çeviririk. Foto tort, 3D tort, fondant tort — istədiyiniz hər şeyi hazırlaya bilərik.</p>
                    <a class="text-uppercase text-dark" asp-controller="Menu" asp-action="Index">Ətraflı <i class="bi bi-arrow-right"></i></a>
                </div>
            </div>
            <div class="col-lg-4 col-md-6">
                <div class="bg-primary border-inner text-center text-white p-5">
                    <div class="d-flex align-items-center justify-content-center mx-auto mb-3" style="width: 90px; height: 90px;">
                        <i class="fa fa-truck fa-3x text-dark"></i>
                    </div>
                    <h4 class="text-uppercase mb-3">Çatdırılma</h4>
                    <p>Bakı şəhəri daxilində pulsuz çatdırılma xidməti. Tortlarınız xüsusi qutularda təhlükəsiz şəkildə çatdırılır.</p>
                    <a class="text-uppercase text-dark" asp-controller="Contact" asp-action="Index">Sifariş Et <i class="bi bi-arrow-right"></i></a>
                </div>
            </div>
            <div class="col-lg-4 col-md-6">
                <div class="bg-primary border-inner text-center text-white p-5">
                    <div class="d-flex align-items-center justify-content-center mx-auto mb-3" style="width: 90px; height: 90px;">
                        <i class="fa fa-glass-cheers fa-3x text-dark"></i>
                    </div>
                    <h4 class="text-uppercase mb-3">Korporativ Tədbirlər</h4>
                    <p>Şirkət tədbirləri, konfranslar və bayramlar üçün toplu tort sifarişləri. Loqonuz ilə xüsusi tortlar hazırlayırıq.</p>
                    <a class="text-uppercase text-dark" asp-controller="Contact" asp-action="Index">Əlaqə <i class="bi bi-arrow-right"></i></a>
                </div>
            </div>
            <div class="col-lg-4 col-md-6">
                <div class="bg-primary border-inner text-center text-white p-5">
                    <div class="d-flex align-items-center justify-content-center mx-auto mb-3" style="width: 90px; height: 90px;">
                        <i class="fa fa-cookie-bite fa-3x text-dark"></i>
                    </div>
                    <h4 class="text-uppercase mb-3">Desert Bufeti</h4>
                    <p>Toy, nişan və xüsusi tədbirlər üçün cupcake, macarons, cake pops və digər desertlərdən ibarət bufet xidməti.</p>
                    <a class="text-uppercase text-dark" asp-controller="Contact" asp-action="Index">Əlaqə <i class="bi bi-arrow-right"></i></a>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- Service End -->
