                        <div class="col-lg-6">
                            <div class="d-flex h-100">
                                <div class="flex-shrink-0">
                                    <img class="img-fluid" src="~/assets/img/cake-1.jpg" alt="Ad günü tortu" style="width: 150px; height: 85px;">
