                            <div class="d-flex h-100">
                                <div class="flex-shrink-0">
                                    <img class="img-fluid" src="~/assets/img/cake-3.jpg" alt="Mini tortlar" style="width: 150px; height: 85px;">
                                    <h4 class="bg-dark text-primary p-2 m-0">₼35.00</h4>
                                </div>
                                <div class="d-flex flex-column justify-content-center text-start bg-secondary border-inner px-4">
                                    <h5 class="text-uppercase">Mini Tortlar (6 ədəd)</h5>
                                    <span>Müxtəlif dadlarda hazırlanmış mini tort dəsti, qonaqlar üçün ideal</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
