                    <a class="nav-link text-white active" data-bs-toggle="pill" href="#tab-1">Ad Günü</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link text-white" data-bs-toggle="pill" href="#tab-2">Toy</a>
