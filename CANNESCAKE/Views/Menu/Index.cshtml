@model IEnumerable<CANNESCAKE.Models.Category>

@{
    ViewData["Title"] = "Menu & Pricing";
}

<!-- Page Header Start -->
<div class="container-fluid bg-dark bg-img p-5 mb-5">
    <div class="row">
        <div class="col-12 text-center">
            <h1 class="display-4 text-uppercase text-white">Menu & Qiymətlər</h1>
            <a asp-controller="Home" asp-action="Index">Home</a>
            <i class="far fa-square text-primary px-2"></i>
            <a asp-controller="Menu" asp-action="Index">Menu</a>
        </div>
    </div>
</div>
<!-- Page Header End -->

<!-- Products Start -->
<div class="container-fluid about py-5">
    <div class="container">
        <div class="section-title position-relative text-center mx-auto mb-5 pb-3" style="max-width: 600px;">
            <h2 class="text-primary font-secondary">Menu & Qiymətlər</h2>
            <h1 class="display-4 text-uppercase">Tortlarımızı Kəşf Edin</h1>
        </div>
        <div class="tab-class text-center">
            <ul class="nav nav-pills d-inline-flex justify-content-center bg-dark text-uppercase border-inner p-4 mb-5">
                @{ var catIndex = 0; }
                @foreach (var category in Model)
                {
                    <li class="nav-item">
                        <a class="nav-link text-white @(catIndex == 0 ? "active" : "")" data-bs-toggle="pill" href="#tab-@category.Id">@category.Name</a>
                    </li>
                    catIndex++;
                }
            </ul>
            <div class="tab-content">
                @{ catIndex = 0; }
                @foreach (var category in Model)
                {
                    <div id="tab-@category.Id" class="tab-pane fade show p-0 @(catIndex == 0 ? "active" : "")">
                        <div class="row g-3">
                            @foreach (var cake in category.Cakes)
                            {
                                <div class="col-lg-6">
                                    <div class="d-flex h-100">
                                        <div class="flex-shrink-0">
                                            @if (!string.IsNullOrEmpty(cake.ImageUrl))
                                            {
                                                <img class="img-fluid" src="@cake.ImageUrl" alt="@cake.Name" style="width: 150px; height: 85px; object-fit: cover;">
                                            }
                                            else
                                            {
                                                <img class="img-fluid" src="~/assets/img/cake-1.jpg" alt="@cake.Name" style="width: 150px; height: 85px;">
                                            }
                                            <h4 class="bg-dark text-primary p-2 m-0">₼@cake.Price.ToString("F2")</h4>
                                        </div>
                                        <div class="d-flex flex-column justify-content-center text-start bg-secondary border-inner px-4">
                                            <h5 class="text-uppercase">@cake.Name</h5>
                                            <span>@cake.Description</span>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                    catIndex++;
                }
            </div>
        </div>
    </div>
</div>
<!-- Products End -->

<!-- Offer Start -->
<div class="container-fluid bg-offer my-5 py-5">
    <div class="container py-5">
        <div class="row gx-5 justify-content-center">
            <div class="col-lg-7 text-center">
                <div class="section-title position-relative text-center mx-auto mb-4 pb-3" style="max-width: 600px;">
                    <h2 class="text-primary font-secondary">Xüsusi Kombo Paket</h2>
                    <h1 class="display-4 text-uppercase text-white">Super Dadlı Tortlar</h1>
                </div>
                <p class="text-white mb-4">Xüsusi münasibətlər üçün kombo paketlərimizdən yararlanın. Ad günü, nişan və ya toy üçün tort + cupcake + macarons dəsti sifariş edin və 20% endirim qazanın!</p>
                <a asp-controller="Contact" asp-action="Index" class="btn btn-primary border-inner py-3 px-5 me-3">Sifariş Et</a>
                <a asp-controller="About" asp-action="Index" class="btn btn-dark border-inner py-3 px-5">Ətraflı</a>
            </div>
        </div>
    </div>
</div>
<!-- Offer End -->
