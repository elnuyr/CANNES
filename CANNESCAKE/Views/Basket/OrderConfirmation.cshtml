@model CANNESCAKE.Models.Order

@{
    ViewData["Title"] = "Sifariş Təsdiqi";
}

<!-- Page Header Start -->
<div class="container-fluid bg-dark bg-img p-5 mb-5">
    <div class="row">
        <div class="col-12 text-center">
            <h1 class="display-4 text-uppercase text-white">Sifariş Təsdiqi</h1>
            <a asp-controller="Home" asp-action="Index">Home</a>
            <i class="far fa-square text-primary px-2"></i>
            <span class="text-white">Sifariş Təsdiqi</span>
        </div>
    </div>
</div>
<!-- Page Header End -->

<!-- Order Confirmation Start -->
<div class="container-fluid py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <!-- Uğur mesajı -->
                <div class="text-center mb-5">
                    <div class="mb-4">
                        <i class="fas fa-check-circle text-success" style="font-size: 80px;"></i>
                    </div>
                    <h2 class="text-uppercase text-primary mb-3">Sifarişiniz Qəbul Edildi!</h2>
                    <p class="text-muted fs-5">Təşəkkür edirik, @Model.CustomerName! Sifarişiniz uğurla qəbul olundu.</p>
                </div>

                <!-- Sifariş detalları -->
                <div class="bg-dark border-inner p-4 p-md-5 mb-4">
                    <h4 class="text-uppercase text-white mb-4"><i class="fas fa-receipt me-2 text-primary"></i>Sifariş Detalları</h4>

                    <div class="row mb-3">
                        <div class="col-6">
                            <span class="text-muted">Sifariş nömrəsi:</span><br />
                            <span class="text-primary fw-bold fs-5">#@Model.Id</span>
                        </div>
                        <div class="col-6 text-end">
                            <span class="text-muted">Sifariş tarixi:</span><br />
                            <span class="text-white">@Model.OrderDate.ToString("dd.MM.yyyy HH:mm")</span>
                        </div>
                    </div>

                    <hr style="border-color: #2a2a35;" />

                    <div class="row mb-2">
                        <div class="col-sm-6 mb-2">
                            <span class="text-muted">Müştəri:</span><br />
                            <span class="text-white">@Model.CustomerName</span>
                        </div>
                        <div class="col-sm-6 mb-2">
                            <span class="text-muted">E-poçt:</span><br />
                            <span class="text-white">@Model.CustomerEmail</span>
                        </div>
                    </div>
                    <div class="row mb-2">
                        <div class="col-sm-6 mb-2">
                            <span class="text-muted">Telefon:</span><br />
                            <span class="text-white">@Model.CustomerPhone</span>
                        </div>
                        @if (!string.IsNullOrEmpty(Model.DeliveryAddress))
                        {
                            <div class="col-sm-6 mb-2">
                                <span class="text-muted">Çatdırılma ünvanı:</span><br />
                                <span class="text-white">@Model.DeliveryAddress</span>
                            </div>
                        }
                    </div>

                    <hr style="border-color: #2a2a35;" />

                    <h5 class="text-white text-uppercase mb-3">Sifariş olunan məhsullar</h5>

                    @foreach (var item in Model.OrderItems)
                    {
                        <div class="d-flex align-items-center mb-3 pb-3" style="border-bottom: 1px solid #2a2a35;">
                            @if (item.Cake != null && !string.IsNullOrEmpty(item.Cake.ImageUrl))
                            {
                                <img src="@item.Cake.ImageUrl" alt="@item.Cake?.Name" class="rounded" style="width: 50px; height: 50px; object-fit: cover;">
                            }
                            else
                            {
                                <img src="~/assets/img/cake-1.jpg" alt="Tort" class="rounded" style="width: 50px; height: 50px; object-fit: cover;">
                            }
                            <div class="ms-3 flex-grow-1">
                                <h6 class="text-white text-uppercase mb-0" style="font-size: 0.85rem;">@(item.Cake?.Name ?? "Tort")</h6>
                                <small class="text-muted">@item.Quantity x ₼@item.UnitPrice.ToString("F2")</small>
                            </div>
                            <span class="text-primary fw-bold">₼@item.TotalPrice.ToString("F2")</span>
                        </div>
                    }

                    <div class="d-flex justify-content-between mt-3">
                        <span class="text-white fs-5 fw-bold">Ümumi Cəm:</span>
                        <span class="text-primary fs-4 fw-bold">₼@Model.TotalPrice.ToString("F2")</span>
                    </div>
                </div>

                <!-- Status -->
                <div class="bg-secondary border-inner p-4 mb-4 text-center">
                    <h5 class="text-uppercase mb-2">Sifariş Statusu</h5>
                    <span class="badge bg-warning text-dark fs-6 px-4 py-2">@Model.Status</span>
                    <p class="mt-3 mb-0 text-muted">Sifarişiniz tezliklə emal olunacaq. Sizinlə əlaqə saxlanılacaq.</p>
                </div>

                <!-- Düymələr -->
                <div class="text-center">
                    <a asp-controller="Menu" asp-action="Index" class="btn btn-primary border-inner py-3 px-5 me-2">
                        <i class="fas fa-birthday-cake me-2"></i>Alış-verişə Davam Et
                    </a>
                    <a asp-controller="Home" asp-action="Index" class="btn btn-dark border-inner py-3 px-5">
                        <i class="fas fa-home me-2"></i>Ana Səhifə
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- Order Confirmation End -->
