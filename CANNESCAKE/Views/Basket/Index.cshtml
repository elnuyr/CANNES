@model List<CANNESCAKE.Models.ViewModels.CartItemViewModel>

@{
    ViewData["Title"] = "Səbət";
}

<!-- Page Header Start -->
<div class="container-fluid bg-dark bg-img p-5 mb-5">
    <div class="row">
        <div class="col-12 text-center">
            <h1 class="display-4 text-uppercase text-white">Səbət</h1>
            <a asp-controller="Home" asp-action="Index">Home</a>
            <i class="far fa-square text-primary px-2"></i>
            <a asp-controller="Basket" asp-action="Index">Səbət</a>
        </div>
    </div>
</div>
<!-- Page Header End -->

<!-- Basket Start -->
<div class="container-fluid py-5">
    <div class="container">
        <div class="section-title position-relative text-center mx-auto mb-5 pb-3" style="max-width: 600px;">
            <h2 class="text-primary font-secondary">Səbətim</h2>
            <h1 class="display-4 text-uppercase">Seçdiyiniz Tortlar</h1>
        </div>

        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger text-center mb-4">
                <i class="fas fa-exclamation-circle me-2"></i>@TempData["ErrorMessage"]
            </div>
        }

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success text-center mb-4">
                <i class="fas fa-check-circle me-2"></i>@TempData["SuccessMessage"]
            </div>
        }

        @if (Model.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle" style="background-color: #1b1b22; border-radius: 8px; overflow: hidden;">
                    <thead style="background-color: #E88F2A;">
                        <tr>
                            <th class="text-white text-uppercase py-3 ps-4" style="border:none;">Məhsul</th>
                            <th class="text-white text-uppercase py-3 text-center" style="border:none;">Qiymət</th>
                            <th class="text-white text-uppercase py-3 text-center" style="border:none;">Miqdar</th>
                            <th class="text-white text-uppercase py-3 text-center" style="border:none;">Cəm</th>
                            <th class="text-white text-uppercase py-3 text-center pe-4" style="border:none;">Əməliyyat</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr style="border-bottom: 1px solid #2a2a35;">
                                <td class="py-3 ps-4" style="border:none;">
                                    <div class="d-flex align-items-center">
                                        @if (!string.IsNullOrEmpty(item.ImageUrl))
                                        {
                                            <img src="@item.ImageUrl" alt="@item.CakeName" class="rounded" style="width: 70px; height: 70px; object-fit: cover;">
                                        }
                                        else
                                        {
                                            <img src="~/assets/img/cake-1.jpg" alt="@item.CakeName" class="rounded" style="width: 70px; height: 70px; object-fit: cover;">
                                        }
                                        <div class="ms-3">
                                            <h6 class="text-white text-uppercase mb-0">@item.CakeName</h6>
                                        </div>
                                    </div>
                                </td>
                                <td class="text-center py-3" style="border:none;">
                                    <span class="text-primary fw-bold">₼@item.Price.ToString("F2")</span>
                                </td>
                                <td class="text-center py-3" style="border:none;">
                                    <form asp-action="UpdateQuantity" method="post" class="d-inline-flex align-items-center justify-content-center">
                                        <input type="hidden" name="cakeId" value="@item.CakeId" />
                                        <div class="input-group" style="width: 130px;">
                                            <button type="button" class="btn btn-outline-primary btn-sm qty-minus" style="border-color: #E88F2A;">
                                                <i class="fas fa-minus"></i>
                                            </button>
                                            <input type="number" name="quantity" value="@item.Quantity" min="1" max="100"
                                                   class="form-control text-center text-white bg-transparent border-primary qty-input" style="border-color: #E88F2A;">
                                            <button type="button" class="btn btn-outline-primary btn-sm qty-plus" style="border-color: #E88F2A;">
                                                <i class="fas fa-plus"></i>
                                            </button>
                                        </div>
                                        <button type="submit" class="btn btn-sm btn-primary ms-2" title="Yenilə">
                                            <i class="fas fa-sync-alt"></i>
                                        </button>
                                    </form>
                                </td>
                                <td class="text-center py-3" style="border:none;">
                                    <span class="text-white fw-bold fs-5">₼@item.TotalPrice.ToString("F2")</span>
                                </td>
                                <td class="text-center py-3 pe-4" style="border:none;">
                                    <form asp-action="RemoveFromCart" method="post" class="d-inline">
                                        <input type="hidden" name="cakeId" value="@item.CakeId" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger" title="Sil">
                                            <i class="fas fa-trash-alt"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- Ümumi cəm və düymələr -->
            <div class="row mt-4">
                <div class="col-lg-6">
                    <a asp-controller="Menu" asp-action="Index" class="btn btn-dark border-inner py-3 px-5">
                        <i class="fas fa-arrow-left me-2"></i>Alış-verişə Davam Et
                    </a>
                </div>
                <div class="col-lg-6">
                    <div class="bg-dark border-inner p-4 text-end">
                        <h4 class="text-white text-uppercase mb-3">Sifariş Xülasəsi</h4>
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-white">Məhsul sayı:</span>
                            <span class="text-primary fw-bold">@Model.Sum(x => x.Quantity) ədəd</span>
                        </div>
                        <hr style="border-color: #E88F2A;" />
                        <div class="d-flex justify-content-between mb-3">
                            <span class="text-white fs-5">Ümumi Cəm:</span>
                            <span class="text-primary fw-bold fs-4">₼@Model.Sum(x => x.TotalPrice).ToString("F2")</span>
                        </div>
                        <a asp-action="Checkout" class="btn btn-primary border-inner py-3 px-5 w-100 text-uppercase fw-bold" id="checkoutBtn">
                            <i class="fas fa-shopping-bag me-2"></i>Sifariş Et
                        </a>
                    </div>
                </div>
            </div>
        }
        else
        {
            <div class="text-center py-5">
                <div class="mb-4">
                    <i class="fas fa-shopping-cart text-primary" style="font-size: 80px; opacity: 0.5;"></i>
                </div>
                <h3 class="text-uppercase mb-3">Səbətiniz Boşdur</h3>
                <p class="text-muted mb-4">Hələ heç bir tort əlavə etməmisiniz. Menyumuza baxıb sevdiyiniz tortları seçin!</p>
                <a asp-controller="Menu" asp-action="Index" class="btn btn-primary border-inner py-3 px-5">
                    <i class="fas fa-birthday-cake me-2"></i>Menyuya Keç
                </a>
            </div>
        }
    </div>
</div>
<!-- Basket End -->

@section Scripts {
    <script>
        $(document).ready(function () {
            // Miqdar artırma/azaltma düymələri
            $(document).on('click', '.qty-minus', function () {
                var input = $(this).closest('.input-group').find('.qty-input');
                var val = parseInt(input.val()) - 1;
                if (val >= 1) {
                    input.val(val);
                    $(this).closest('form').submit(); // Avtomatik submit
                }
            });
            $(document).on('click', '.qty-plus', function () {
                var input = $(this).closest('.input-group').find('.qty-input');
                var val = parseInt(input.val()) + 1;
                if (val <= 100) {
                    input.val(val);
                    $(this).closest('form').submit(); // Avtomatik submit
                }
            });
            // Manual daxil etmə olduqda
            $(document).on('change', '.qty-input', function () {
                $(this).closest('form').submit();
            });
        });
    </script>
}
