@model CANNESCAKE.Models.ViewModels.CheckoutViewModel

@{
    ViewData["Title"] = "Sifariş Et";
}

<!-- Page Header Start -->
<div class="container-fluid bg-dark bg-img p-5 mb-5">
    <div class="row">
        <div class="col-12 text-center">
            <h1 class="display-4 text-uppercase text-white">Sifariş Et</h1>
            <a asp-controller="Home" asp-action="Index">Home</a>
            <i class="far fa-square text-primary px-2"></i>
            <a asp-controller="Basket" asp-action="Index">Səbət</a>
            <i class="far fa-square text-primary px-2"></i>
            <a asp-controller="Basket" asp-action="Checkout">Sifariş</a>
        </div>
    </div>
</div>
<!-- Page Header End -->

<!-- Checkout Start -->
<div class="container-fluid py-5">
    <div class="container">
        <div class="section-title position-relative text-center mx-auto mb-5 pb-3" style="max-width: 600px;">
            <h2 class="text-primary font-secondary">Sifariş</h2>
            <h1 class="display-4 text-uppercase">Sifarişi Tamamla</h1>
        </div>

        <form asp-action="PlaceOrder" method="post">
            <div class="row g-5">
                <!-- Sol tərəf - Müştəri məlumatları -->
                <div class="col-lg-7">
                    <div class="bg-secondary border-inner p-4 p-md-5">
                        <h4 class="text-uppercase mb-4"><i class="fas fa-user me-2 text-primary"></i>Çatdırılma Məlumatları</h4>
                        <div class="row g-3">
                            <div class="col-md-12">
                                <div class="form-floating">
                                    <input type="text" name="CustomerName" value="@Model.CustomerName" class="form-control border-0" placeholder="Ad və Soyad" required>
                                    <label>Ad və Soyad *</label>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-floating">
                                    <input type="email" name="CustomerEmail" value="@Model.CustomerEmail" class="form-control border-0" placeholder="E-poçt" required>
                                    <label>E-poçt *</label>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-floating">
                                    <input type="tel" name="CustomerPhone" class="form-control border-0" placeholder="Telefon" required>
                                    <label>Telefon nömrəsi *</label>
                                </div>
                            </div>
                            <div class="col-12">
                                <div class="form-floating">
                                    <input type="text" name="DeliveryAddress" class="form-control border-0" placeholder="Çatdırılma ünvanı">
                                    <label>Çatdırılma ünvanı</label>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-floating">
                                    <input type="date" name="DeliveryDate" class="form-control border-0" min="@DateTime.Now.AddDays(1).ToString("yyyy-MM-dd")">
                                    <label>İstənilən çatdırılma tarixi</label>
                                </div>
                            </div>
                            <div class="col-12">
                                <div class="form-floating">
                                    <textarea name="Notes" class="form-control border-0" placeholder="Qeydlər" style="height: 120px;"></textarea>
                                    <label>Əlavə qeydlər (isteğe bağlı)</label>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Sağ tərəf - Sifariş xülasəsi -->
                <div class="col-lg-5">
                    <div class="bg-dark border-inner p-4 p-md-5">
                        <h4 class="text-uppercase text-white mb-4"><i class="fas fa-shopping-bag me-2 text-primary"></i>Sifariş Xülasəsi</h4>

                        @foreach (var item in Model.CartItems)
                        {
                            <div class="d-flex align-items-center mb-3 pb-3" style="border-bottom: 1px solid #2a2a35;">
                                @if (!string.IsNullOrEmpty(item.ImageUrl))
                                {
                                    <img src="@item.ImageUrl" alt="@item.CakeName" class="rounded" style="width: 55px; height: 55px; object-fit: cover;">
                                }
                                else
                                {
                                    <img src="~/assets/img/cake-1.jpg" alt="@item.CakeName" class="rounded" style="width: 55px; height: 55px; object-fit: cover;">
                                }
                                <div class="ms-3 flex-grow-1">
                                    <h6 class="text-white text-uppercase mb-1" style="font-size: 0.85rem;">@item.CakeName</h6>
                                    <small class="text-muted">@item.Quantity x ₼@item.Price.ToString("F2")</small>
                                </div>
                                <span class="text-primary fw-bold">₼@item.TotalPrice.ToString("F2")</span>
                            </div>
                        }

                        <hr style="border-color: #E88F2A;" />

                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-white">Məhsul sayı:</span>
                            <span class="text-white">@Model.CartItems.Sum(x => x.Quantity) ədəd</span>
                        </div>
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-white">Çatdırılma:</span>
                            <span class="text-primary">Pulsuz</span>
                        </div>

                        <hr style="border-color: #E88F2A;" />

                        <div class="d-flex justify-content-between mb-4">
                            <span class="text-white fs-5 fw-bold">Ümumi Cəm:</span>
                            <span class="text-primary fs-4 fw-bold">₼@Model.GrandTotal.ToString("F2")</span>
                        </div>

                        <button type="submit" class="btn btn-primary border-inner py-3 w-100 text-uppercase fw-bold" id="placeOrderBtn">
                            <i class="fas fa-check-circle me-2"></i>Sifarişi Təsdiqlə
                        </button>

                        <div class="text-center mt-3">
                            <a asp-action="Index" class="text-primary">
                                <i class="fas fa-arrow-left me-1"></i>Səbətə qayıt
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>
<!-- Checkout End -->
