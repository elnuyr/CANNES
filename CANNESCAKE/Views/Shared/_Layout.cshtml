<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8">
    <title>@ViewData["Title"] - CANNES CAKE</title>
    <meta content="width=device-width, initial-scale=1.0" name="viewport">
    <meta content="CANNES CAKE, tort, pasta, sifarish" name="keywords">
    <meta content="CANNES CAKE - Ən dadlı tortlar" name="description">

    <!-- Favicon -->
    <link href="~/assets/img/favicon.ico" rel="icon">

    <!-- Google Web Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Open+Sans:wght@400;600&family=Oswald:wght@500;600;700&family=Pacifico&display=swap" rel="stylesheet">

    <!-- Icon Font Stylesheet -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.10.0/css/all.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.4.1/font/bootstrap-icons.css" rel="stylesheet">

    <!-- Libraries Stylesheet -->
    <link href="~/assets/lib/owlcarousel/assets/owl.carousel.min.css" rel="stylesheet">

    <!-- Customized Bootstrap Stylesheet -->
    <link href="~/assets/css/bootstrap.min.css" rel="stylesheet">

    <!-- Template Stylesheet -->
    <link href="~/assets/css/style.css" rel="stylesheet">
</head>

<body>
    <!-- Topbar Start -->
    <div class="container-fluid px-0 d-none d-lg-block">
        <div class="row gx-0">
            <div class="col-lg-4 text-center bg-secondary py-3">
                <div class="d-inline-flex align-items-center justify-content-center">
                    <i class="bi bi-envelope fs-1 text-primary me-3"></i>
                    <div class="text-start">
                        <h6 class="text-uppercase mb-1">E-poçt</h6>
                        <span>info@cannescake.az</span>
                    </div>
                </div>
            </div>
            <div class="col-lg-4 text-center bg-primary border-inner py-3">
                <div class="d-inline-flex align-items-center justify-content-center">
                    <a asp-controller="Home" asp-action="Index" class="navbar-brand">
                        <h1 class="m-0 text-uppercase text-white"><i class="fa fa-birthday-cake fs-1 text-dark me-3"></i>Cannes Cake</h1>
                    </a>
                </div>
            </div>
            <div class="col-lg-4 text-center bg-secondary py-3">
                <div class="d-inline-flex align-items-center justify-content-center">
                    <i class="bi bi-phone-vibrate fs-1 text-primary me-3"></i>
                    <div class="text-start">
                        <h6 class="text-uppercase mb-1">Zəng Edin</h6>
                        <span>+994 50 123 45 67</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!-- Topbar End -->
    <!-- Navbar Start -->
    <nav class="navbar navbar-expand-lg bg-dark navbar-dark shadow-sm py-3 py-lg-0 px-3 px-lg-0">
        <a asp-controller="Home" asp-action="Index" class="navbar-brand d-block d-lg-none">
            <h1 class="m-0 text-uppercase text-white"><i class="fa fa-birthday-cake fs-1 text-primary me-3"></i>Cannes Cake</h1>
        </a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarCollapse">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarCollapse">
            <div class="navbar-nav ms-auto mx-lg-auto py-0">
                <a asp-controller="Home" asp-action="Index" class="nav-item nav-link">Ana Səhifə</a>
                <a asp-controller="About" asp-action="Index" class="nav-item nav-link">Haqqımızda</a>
                <a asp-controller="Menu" asp-action="Index" class="nav-item nav-link">Menyu & Qiymətlər</a>
                <a asp-controller="Team" asp-action="Index" class="nav-item nav-link">Usta Aşpazlar</a>
                <div class="nav-item dropdown">
                    <a href="#" class="nav-link dropdown-toggle" data-bs-toggle="dropdown">Səhifələr</a>
                    <div class="dropdown-menu m-0">
                        <a asp-controller="Service" asp-action="Index" class="dropdown-item">Xidmətlərimiz</a>
                        <a asp-controller="Testimonial" asp-action="Index" class="dropdown-item">Müştəri Rəyləri</a>
                    </div>
                </div>
                <a asp-controller="Contact" asp-action="Index" class="nav-item nav-link">Əlaqə</a>
                <a asp-controller="Basket" asp-action="Index" class="nav-item nav-link position-relative" style="color:#E88F2A">
                    <i class="fas fa-shopping-cart"></i> Səbət
                    <span id="cartBadge" class="badge bg-danger position-absolute" style="top: 5px; right: -5px; font-size: 0.65rem;">0</span>
                </a>
                
                @if (User.Identity!.IsAuthenticated)
                {
                    <div class="nav-item dropdown">
                        <a href="#" class="nav-link dropdown-toggle" data-bs-toggle="dropdown" style="color:#E88F2A">Hesabım (@User.Identity.Name)</a>
                        <div class="dropdown-menu m-0">
                            <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                <button type="submit" class="dropdown-item text-danger border-0 bg-transparent" style="text-align:left;">Çıxış Et</button>
                            </form>
                        </div>
                    </div>
                }
                else
                {
                    <a asp-controller="Account" asp-action="Login" class="nav-item nav-link" style="color:#E88F2A">Daxil Ol</a>
                    <a asp-controller="Account" asp-action="Register" class="nav-item nav-link" style="color:#E88F2A">Qeydiyyat</a>
                }
            </div>
        </div>
    </nav>
    <!-- Navbar End -->
            @RenderBody()
    <!-- Footer Start -->
    <div class="container-fluid bg-img text-secondary" style="margin-top: 90px">
        <div class="container">
            <div class="row gx-5">
                <div class="col-lg-4 col-md-6 mb-lg-n5">
                    <div class="d-flex flex-column align-items-center justify-content-center text-center h-100 bg-primary border-inner p-4">
                        <a asp-controller="Home" asp-action="Index" class="navbar-brand">
                            <h1 class="m-0 text-uppercase text-white"><i class="fa fa-birthday-cake fs-1 text-dark me-3"></i>Cannes Cake</h1>
                        </a>
                        <p class="mt-3">Cannes Cake olaraq, hər bir tortumuz sevgi və ustalıqla hazırlanır. Təbii inqrediyentlərlə keyfiyyətli tortlar təqdim edirik. Ad günü, toy, nişan və xüsusi münasibətlər üçün sifariş edin!</p>
                    </div>
                </div>
                <div class="col-lg-8 col-md-6">
                    <div class="row gx-5">
                        <div class="col-lg-4 col-md-12 pt-5 mb-5">
                            <h4 class="text-primary text-uppercase mb-4">Əlaqə</h4>
                            <div class="d-flex mb-2">
                                <i class="bi bi-geo-alt text-primary me-2"></i>
                                <p class="mb-0">Bakı, Nəsimi rayonu, Nizami küç. 50</p>
                            </div>
                            <div class="d-flex mb-2">
                                <i class="bi bi-envelope-open text-primary me-2"></i>
                                <p class="mb-0">info@cannescake.az</p>
                            </div>
                            <div class="d-flex mb-2">
                                <i class="bi bi-telephone text-primary me-2"></i>
                                <p class="mb-0">+994 50 123 45 67</p>
                            </div>
                            <div class="d-flex mt-4">
                                <a class="btn btn-lg btn-primary btn-lg-square border-inner rounded-0 me-2" href="#"><i class="fab fa-twitter fw-normal"></i></a>
                                <a class="btn btn-lg btn-primary btn-lg-square border-inner rounded-0 me-2" href="#"><i class="fab fa-facebook-f fw-normal"></i></a>
                                <a class="btn btn-lg btn-primary btn-lg-square border-inner rounded-0 me-2" href="#"><i class="fab fa-linkedin-in fw-normal"></i></a>
                            </div>
                        </div>
                        <div class="col-lg-4 col-md-12 pt-0 pt-lg-5 mb-5">
                            <h4 class="text-primary text-uppercase mb-4">Sürətli Keçidlər</h4>
                            <div class="d-flex flex-column justify-content-start">
                                <a class="text-secondary mb-2" asp-controller="Home" asp-action="Index"><i class="bi bi-arrow-right text-primary me-2"></i>Ana Səhifə</a>
                                <a class="text-secondary mb-2" asp-controller="About" asp-action="Index"><i class="bi bi-arrow-right text-primary me-2"></i>Haqqımızda</a>
                                <a class="text-secondary mb-2" asp-controller="Menu" asp-action="Index"><i class="bi bi-arrow-right text-primary me-2"></i>Menyu</a>
                                <a class="text-secondary mb-2" asp-controller="Contact" asp-action="Index"><i class="bi bi-arrow-right text-primary me-2"></i>Əlaqə</a>
                            </div>
                        </div>
                        <div class="col-lg-4 col-md-12 pt-0 pt-lg-5 mb-5">
                            <h4 class="text-primary text-uppercase mb-4">Bülletenlər</h4>
                            <p>Yeniliklərdən xəbərdar olmaq üçün e-poçt ünvanınızı daxil edin</p>
                            <form action="">
                                <div class="input-group">
                                    <input type="text" class="form-control border-white p-3" placeholder="E-poçt ünvanınız">
                                    <button class="btn btn-primary">Abunə Ol</button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="container-fluid text-secondary py-4" style="background: #111111;">
        <div class="container text-center">
            <p class="mb-0">
                &copy; <a class="text-white border-bottom" asp-controller="Home" asp-action="Index">Cannes Cake</a>. Bütün hüquqlar qorunur.

                <!--/*** The author’s attribution link must remain intact in the template. ***/-->
                <!--/*** If you wish to remove this credit link, please purchase the Pro Version . ***/-->
                Dizayn: <a class="text-white border-bottom" href="https://htmlcodex.com">HTML Codex</a>
            </p>
        </div>
    </div>
    <!-- Footer End -->
    <!-- Yuxarı Qayıt -->
    <a href="#" class="btn btn-primary border-inner py-3 fs-4 back-to-top"><i class="bi bi-arrow-up"></i></a>


    <!-- JavaScript Libraries -->
    <script src="https://code.jquery.com/jquery-3.4.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/assets/lib/easing/easing.min.js"></script>
    <script src="~/assets/lib/waypoints/waypoints.min.js"></script>
    <script src="~/assets/lib/counterup/counterup.min.js"></script>
    <script src="~/assets/lib/owlcarousel/owl.carousel.min.js"></script>

    <!-- Template Javascript -->
    <script src="~/assets/js/main.js"></script>

    @RenderSection("Scripts", required: false)

    <script>
        // Səbət sayını yüklə
        $(document).ready(function () {
            $.get('/Basket/GetCartCount', function (data) {
                if (data.count > 0) {
                    $('#cartBadge').text(data.count).show();
                } else {
                    $('#cartBadge').hide();
                }
            });
        });
    </script>
</body>

</html>
