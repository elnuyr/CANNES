@model IEnumerable<CANNESCAKE.Models.Order>

@{
    ViewData["Title"] = "Sifarişlər";
}

<div class="row">
    <div class="col-lg-12 grid-margin stretch-card">
        <div class="card">
            <div class="card-body">
                <h4 class="card-title">Sifarişlər</h4>
                <div class="table-responsive">
                    <table class="table table-striped">
                        <thead>
                            <tr>
                                <th>
                                    Sifariş №
                                </th>
                                <th>
                                    Müştəri
                                </th>
                                <th>
                                    Telefon
                                </th>
                                <th>
                                    Məbləğ
                                </th>
                                <th>
                                    Tarix
                                </th>
                                <th>
                                    Status
                                </th>
                                <th>Əməliyyatlar</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model) {
                                <tr>
                                    <td>
                                        #@item.Id
                                    </td>
                                    <td>
                                        @Html.DisplayFor(modelItem => item.CustomerName)
                                    </td>
                                    <td>
                                        @Html.DisplayFor(modelItem => item.CustomerPhone)
                                    </td>
                                    <td>
                                        @Html.DisplayFor(modelItem => item.TotalPrice) ₼
                                    </td>
                                    <td>
                                        @item.OrderDate.ToString("dd.MM.yyyy HH:mm")
                                    </td>
                                    <td>
                                        <label class="badge badge-info">@item.Status</label>
                                    </td>
                                    <td>
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-success btn-sm"><i class="mdi mdi-pencil"></i></a>
                                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info btn-sm"><i class="mdi mdi-eye"></i></a>
                                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm"><i class="mdi mdi-delete"></i></a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
