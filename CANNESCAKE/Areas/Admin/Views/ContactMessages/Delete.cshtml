@model CANNESCAKE.Models.ContactMessage

@{
    ViewData["Title"] = "Mesajı Sil";
}

<div class="row">
    <div class="col-md-8 grid-margin stretch-card">
        <div class="card">
            <div class="card-body">
                <h4 class="card-title text-danger"><i class="mdi mdi-alert"></i> Mesajı Sil</h4>
                <p class="text-muted mb-4">Bu mesajı silmək istədiyinizə əminsiniz?</p>
                <table class="table table-borderless">
                    <tr><th style="width: 150px;">Ad</th><td><strong>@Model.Name</strong></td></tr>
                    <tr><th>E-poçt</th><td>@Model.Email</td></tr>
                    <tr><th>Mövzu</th><td>@(Model.Subject ?? "Mövzu yoxdur")</td></tr>
                    <tr><th>Tarix</th><td>@Model.CreatedDate.ToString("dd.MM.yyyy HH:mm")</td></tr>
                </table>
                <form asp-action="Delete" class="mt-3">
                    <input type="hidden" asp-for="Id" />
                    <button type="submit" class="btn btn-danger me-2"><i class="mdi mdi-delete"></i> Bəli, Sil</button>
                    <a asp-action="Index" class="btn btn-light">Xeyr, Geri Qayıt</a>
                </form>
            </div>
        </div>
    </div>
</div>
