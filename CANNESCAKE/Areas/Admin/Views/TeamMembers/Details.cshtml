@model CANNESCAKE.Models.TeamMember

@{
    ViewData["Title"] = "Komanda Üzvü Detalları";
}

<div class="row">
    <div class="col-md-8 grid-margin stretch-card">
        <div class="card">
            <div class="card-body">
                <h4 class="card-title">Komanda Üzvü Detalları</h4>

                <div class="row mt-4">
                    <div class="col-md-4 text-center">
                        @if (!string.IsNullOrEmpty(Model.ImageUrl))
                        {
                            <img src="@Model.ImageUrl" alt="@Model.FullName" class="img-fluid rounded" style="max-height: 250px;" />
                        }
                        else
                        {
                            <div class="d-flex align-items-center justify-content-center bg-light rounded" style="height: 250px;">
                                <i class="mdi mdi-account mdi-48px text-muted"></i>
                            </div>
                        }
                    </div>
                    <div class="col-md-8">
                        <table class="table table-borderless">
                            <tr>
                                <th style="width: 180px;">Ad Soyad</th>
                                <td>@Model.FullName</td>
                            </tr>
                            <tr>
                                <th>Vəzifə</th>
                                <td>@Model.Position</td>
                            </tr>
                            <tr>
                                <th>Sıra Nömrəsi</th>
                                <td>@Model.DisplayOrder</td>
                            </tr>
                            <tr>
                                <th>Facebook</th>
                                <td>
                                    @if (!string.IsNullOrEmpty(Model.FacebookUrl))
                                    {
                                        <a href="@Model.FacebookUrl" target="_blank" class="text-primary">
                                            <i class="mdi mdi-facebook"></i> @Model.FacebookUrl
                                        </a>
                                    }
                                    else
                                    {
                                        <span class="text-muted">Qeyd olunmayıb</span>
                                    }
                                </td>
                            </tr>
                            <tr>
                                <th>Twitter</th>
                                <td>
                                    @if (!string.IsNullOrEmpty(Model.TwitterUrl))
                                    {
                                        <a href="@Model.TwitterUrl" target="_blank" class="text-info">
                                            <i class="mdi mdi-twitter"></i> @Model.TwitterUrl
                                        </a>
                                    }
                                    else
                                    {
                                        <span class="text-muted">Qeyd olunmayıb</span>
                                    }
                                </td>
                            </tr>
                            <tr>
                                <th>Instagram</th>
                                <td>
                                    @if (!string.IsNullOrEmpty(Model.InstagramUrl))
                                    {
                                        <a href="@Model.InstagramUrl" target="_blank" class="text-danger">
                                            <i class="mdi mdi-instagram"></i> @Model.InstagramUrl
                                        </a>
                                    }
                                    else
                                    {
                                        <span class="text-muted">Qeyd olunmayıb</span>
                                    }
                                </td>
                            </tr>
                        </table>
                    </div>
                </div>

                <div class="mt-4">
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-success me-2">
                        <i class="mdi mdi-pencil"></i> Redaktə Et
                    </a>
                    <a asp-action="Index" class="btn btn-light">Geri</a>
                </div>
            </div>
        </div>
    </div>
</div>
