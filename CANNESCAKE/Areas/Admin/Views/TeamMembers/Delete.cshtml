@model CANNESCAKE.Models.TeamMember

@{
    ViewData["Title"] = "Komanda Üzvünü Sil";
}

<div class="row">
    <div class="col-md-8 grid-margin stretch-card">
        <div class="card">
            <div class="card-body">
                <h4 class="card-title text-danger">
                    <i class="mdi mdi-alert"></i> Komanda Üzvünü Sil
                </h4>
                <p class="text-muted mb-4">Bu komanda üzvünü silmək istədiyinizə əminsiniz? Bu əməliyyat geri alına bilməz.</p>

                <div class="row mt-3">
                    <div class="col-md-4 text-center">
                        @if (!string.IsNullOrEmpty(Model.ImageUrl))
                        {
                            <img src="@Model.ImageUrl" alt="@Model.FullName" class="img-fluid rounded" style="max-height: 200px; opacity: 0.7;" />
                        }
                    </div>
                    <div class="col-md-8">
                        <table class="table table-borderless">
                            <tr>
                                <th style="width: 150px;">Ad Soyad</th>
                                <td><strong>@Model.FullName</strong></td>
                            </tr>
                            <tr>
                                <th>Vəzifə</th>
                                <td>@Model.Position</td>
                            </tr>
                            <tr>
                                <th>Sıra Nömrəsi</th>
                                <td>@Model.DisplayOrder</td>
                            </tr>
                        </table>
                    </div>
                </div>

                <form asp-action="Delete" class="mt-4">
                    <input type="hidden" asp-for="Id" />
                    <button type="submit" class="btn btn-danger me-2">
                        <i class="mdi mdi-delete"></i> Bəli, Sil
                    </button>
                    <a asp-action="Index" class="btn btn-light">Xeyr, Geri Qayıt</a>
                </form>
            </div>
        </div>
    </div>
</div>
