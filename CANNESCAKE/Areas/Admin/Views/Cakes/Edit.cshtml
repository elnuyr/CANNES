@model CANNESCAKE.Models.Cake

@{
    ViewData["Title"] = "Tortu Redaktə Et";
}

<div class="row">
    <div class="col-md-8 grid-margin stretch-card">
        <div class="card">
            <div class="card-body">
                <h4 class="card-title">Tortu Redaktə Et</h4>
                <form asp-action="Edit" enctype="multipart/form-data">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="ImageUrl" />
                    <input type="hidden" asp-for="CreatedDate" />
                    <div class="form-group">
                        <label asp-for="Name" class="form-label">Tort Adı</label>
                        <input asp-for="Name" class="form-control" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>
                    <div class="form-group">
                        <label asp-for="Description" class="form-label">Açıqlama</label>
                        <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>
                    <div class="form-group">
                        <label asp-for="Price" class="form-label">Qiymət (₼)</label>
                        <input asp-for="Price" class="form-control" type="number" step="0.01" />
                        <span asp-validation-for="Price" class="text-danger"></span>
                    </div>
                    <div class="form-group">
                        <label asp-for="CategoryId" class="form-label">Kateqoriya</label>
                        <select asp-for="CategoryId" asp-items="@ViewBag.Categories" class="form-control">
                            <option value="">-- Seçin --</option>
                        </select>
                        <span asp-validation-for="CategoryId" class="text-danger"></span>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Mövcud Şəkil</label>
                        @if (!string.IsNullOrEmpty(Model.ImageUrl))
                        {
                            <div class="mb-2">
                                <img src="@Model.ImageUrl" alt="@Model.Name" style="max-height: 150px; border-radius: 8px;" />
                            </div>
                        }
                        <label class="form-label">Yeni Şəkil</label>
                        <input type="file" name="ImageFile" class="form-control" accept="image/*" />
                    </div>
                    <div class="form-group">
                        <div class="form-check">
                            <input asp-for="IsAvailable" class="form-check-input" type="checkbox" />
                            <label asp-for="IsAvailable" class="form-check-label">Mövcuddur</label>
                        </div>
                    </div>
                    <button type="submit" class="btn btn-primary me-2">Yenilə</button>
                    <a asp-action="Index" class="btn btn-light">Geri</a>
                </form>
            </div>
        </div>
    </div>
</div>
