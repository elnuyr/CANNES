@model CANNESCAKE.Models.Testimonial

@{
    ViewData["Title"] = "Rəyi Sil";
}

<div class="row">
    <div class="col-md-8 grid-margin stretch-card">
        <div class="card">
            <div class="card-body">
                <h4 class="card-title text-danger"><i class="mdi mdi-alert"></i> Rəyi Sil</h4>
                <p class="text-muted mb-4">Bu rəyi silmək istədiyinizə əminsiniz?</p>
                <table class="table table-borderless">
                    <tr><th style="width: 150px;">Müştəri</th><td><strong>@Model.ClientName</strong></td></tr>
                    <tr><th>Rəy</th><td>@Model.Comment</td></tr>
                </table>
                <form asp-action="Delete" class="mt-3">
                    <input type="hidden" asp-for="Id" />
                    <button type="submit" class="btn btn-danger me-2"><i class="mdi mdi-delete"></i> Bəli, Sil</button>
                    <a asp-action="Index" class="btn btn-light">Xeyr, Geri Qayıt</a>
                </form>
            </div>
        </div>
    </div>
</div>
