@model CANNESCAKE.Models.Testimonial

@{
    ViewData["Title"] = "Rəy Detalları";
}

<div class="row">
    <div class="col-md-8 grid-margin stretch-card">
        <div class="card">
            <div class="card-body">
                <h4 class="card-title">Müştəri Rəyi Detalları</h4>
                <div class="row mt-4">
                    <div class="col-md-3 text-center">
                        @if (!string.IsNullOrEmpty(Model.ImageUrl))
                        {
                            <img src="@Model.ImageUrl" alt="@Model.ClientName" class="rounded-circle" style="width: 120px; height: 120px; object-fit: cover;" />
                        }
                    </div>
                    <div class="col-md-9">
                        <table class="table table-borderless">
                            <tr><th style="width: 150px;">Müştəri</th><td>@Model.ClientName</td></tr>
                            <tr><th>Peşə</th><td>@(Model.Profession ?? "Qeyd olunmayıb")</td></tr>
                            <tr>
                                <th>Reytinq</th>
                                <td>
                                    @for(int i=0; i<Model.Rating; i++)
                                    {
                                        <i class="mdi mdi-star text-warning"></i>
                                    }
                                </td>
                            </tr>
                            <tr><th>Rəy</th><td>@Model.Comment</td></tr>
                            <tr><th>Status</th><td>@(Model.IsApproved ? "Təsdiqlənib" : "Gözləyir")</td></tr>
                            <tr><th>Tarix</th><td>@Model.CreatedDate.ToString("dd.MM.yyyy HH:mm")</td></tr>
                        </table>
                    </div>
                </div>
                <div class="mt-3">
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-success me-2"><i class="mdi mdi-pencil"></i> Redaktə Et</a>
                    <a asp-action="Index" class="btn btn-light">Geri</a>
                </div>
            </div>
        </div>
    </div>
</div>
